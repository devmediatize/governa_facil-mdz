services:
  mdz-vg:
    build: .
    container_name: mdz-vg
    restart: unless-stopped
    extra_hosts:
      - "host.docker.internal:host-gateway"
    environment:
      - TZ=America/Cuiaba
    volumes:
      # Código principal da aplicação
      - ./app:/app/app:ro
      - ./templates:/app/templates:ro
      - ./static:/app/static:ro

      # Fotos/uploads (leitura e escrita)
      - ./fotos:/app/fotos

      # Scripts e migrações
      - ./scripts:/app/scripts:ro
      - ./migrations:/app/migrations:ro

      # Arquivos de configuração e dependências
      - ./settings.py:/app/settings.py:ro
      - ./requirements.txt:/app/requirements.txt:ro
      - ./.env:/app/.env:ro
    networks:
      - proxy
    labels:
      # Labels gerais
      - "com.docker.stack=mdzvg"
      - "com.docker.service=mdz-vg"

      # Traefik configuração
      - "traefik.enable=true"
      - "traefik.docker.network=proxy"

      # ============================================
      # URL: vg.governafacil.com.br
      # ============================================

      # Roteamento HTTP -> HTTPS
      - "traefik.http.routers.vg.rule=Host(`vg.governafacil.com.br`)"
      - "traefik.http.routers.vg.entrypoints=http"
      - "traefik.http.routers.vg.middlewares=vg-redirect-https@docker"

      # Roteamento HTTPS
      - "traefik.http.routers.vg-secure.rule=Host(`vg.governafacil.com.br`)"
      - "traefik.http.routers.vg-secure.entrypoints=https"
      - "traefik.http.routers.vg-secure.tls=true"
      - "traefik.http.routers.vg-secure.tls.certresolver=letsencrypt"
      - "traefik.http.routers.vg-secure.service=vg-service"

      # ============================================
      # MIDDLEWARES
      # ============================================

      # Middleware para redirect HTTP -> HTTPS
      - "traefik.http.middlewares.vg-redirect-https.redirectscheme.scheme=https"
      - "traefik.http.middlewares.vg-redirect-https.redirectscheme.permanent=true"

      # Serviço - porta interna do container
      - "traefik.http.services.vg-service.loadbalancer.server.port=8000"

networks:
  proxy:
    external: true
