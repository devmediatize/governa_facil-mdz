# ============================================
# CONFIGURACAO DE BACKUP - .env.backup
# ============================================

# Nome do projeto (sera usado no nome do arquivo de backup)
PROJECT_NAME="nome_do_projeto"

# Diretorio de destino do backup
BACKUP_DIR="/caminho/para/backups"

# ============================================
# CONFIGURACAO DO BANCO DE DADOS POSTGRESQL
# ============================================
# Formato: postgresql://usuario:senha@host:porta/nome_banco
# Para multiplos bancos, separe por ";"
#
# Exemplo com um banco:
# DATABASES="postgresql://postgres:senha123@localhost:5432/meu_banco"
#
# Exemplo com multiplos bancos:
# DATABASES="postgresql://user:pass@host:5432/banco1;postgresql://user:pass@host:5432/banco2"

DATABASES="postgresql://usuario:senha@host:5432/nome_banco"

# ============================================
# DIRETORIOS/ARQUIVOS A IGNORAR NO BACKUP
# Separe por virgula, sem espacos
# ============================================
IGNORE_DIRS=".git,node_modules,__pycache__,.venv,venv,.claude,.cache,logs,venv,thema"
IGNORE_FILES="*.log,*.pyc,*.tmp,.DS_Store"

# ============================================
# OPCOES ADICIONAIS
# ============================================
# Manter quantos backups antigos? (0 = manter todos)
KEEP_BACKUPS=10

# Fazer backup do banco de dados? (true/false)
BACKUP_DATABASE=true

# Nivel de compressao (1-9, onde 9 e maximo)
COMPRESSION_LEVEL=6
